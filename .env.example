# MySQL
DB_USERNAME=videostation
DB_PASSWORD=videostation1234

# JWT
JWT_SECRET=

# 파일 저장 경로
STORAGE_ORIGINALS=/data/videos/originals
STORAGE_ENCODED=/data/videos/encoded
STORAGE_THUMBNAILS=/data/videos/thumbnails

# FFmpeg
FFMPEG_PATH=ffmpeg

# 인코딩
ENCODING_MAX_CONCURRENT=2

# NCP Object Storage
NCP_OS_ENABLED=false
NCP_OS_ENDPOINT=https://kr.object.ncloudstorage.com
NCP_OS_REGION=kr-standard
NCP_OS_ACCESS_KEY=
NCP_OS_SECRET_KEY=
NCP_OS_BUCKET=video-station-backup
